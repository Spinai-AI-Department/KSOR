APP_NAME=KSOR API
APP_ENV=production
APP_DEBUG=false
APP_NODE_NAME=ksor-api-01
APP_LOAD_BALANCER_ID=lb-01
PUBLIC_BASE_URL=https://ksor.example.org
API_PREFIX=/api
CORS_ORIGINS=["https://ksor.example.org"]
TRUST_X_FORWARDED_FOR=true

DATABASE_DSN=postgresql://ksor_app:change-me@127.0.0.1:5432/ksor
DB_POOL_MIN_SIZE=10
DB_POOL_MAX_SIZE=80
DB_POOL_TIMEOUT_SECONDS=30
DB_STATEMENT_TIMEOUT_MS=15000
DB_IDLE_IN_TRANSACTION_TIMEOUT_MS=15000

JWT_SECRET_KEY=change-me-super-secret-key-at-least-32-bytes
JWT_ALGORITHM=HS256
JWT_ISSUER=ksor-api
JWT_AUDIENCE=ksor-web
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
SURVEY_TOKEN_EXPIRE_MINUTES=30

FERNET_KEYS=["REPLACE_WITH_BASE64_32BYTE_KEY"]
PASSWORD_REGEX=^(?=.*[A-Za-z])(?=.*\d)(?=.*[^A-Za-z\d]).{8,128}$

DEFAULT_PROM_REQUEST_EXPIRE_DAYS=7
LOGIN_FAILURE_LOCK_COUNT=5
LOGIN_THROTTLE_WINDOW_SECONDS=60
LOGIN_THROTTLE_MAX_PER_IP=30
LOGIN_THROTTLE_MAX_PER_LOGIN_ID=10
LAST_ACTIVE_WRITE_INTERVAL_SECONDS=300

ALIMTALK_VENDOR_MODE=noop
ALIMTALK_API_BASE_URL=
ALIMTALK_SEND_PATH=/send
ALIMTALK_API_KEY=
ALIMTALK_API_SECRET=
ALIMTALK_SENDER_KEY=
ALIMTALK_TIMEOUT_SECONDS=8
ALIMTALK_TEMPLATE_FALLBACK_VENDOR_CODE=generic

OUTBOX_BATCH_SIZE=100
OUTBOX_LEASE_SECONDS=60
OUTBOX_POLL_INTERVAL_SECONDS=1.0
OUTBOX_MAX_CONCURRENCY=50

SECURITY_HEADERS_ENABLED=true
